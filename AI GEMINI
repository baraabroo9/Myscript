-- Bere Hub: Optimized Native Drawing Canvas Engine Master Build
if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local Settings = {
    TargetLock = false,
    VisibilityCheck = false,
    FOVEnabled = true,
    FOV = 130,
    Smoothness = 0.08,
    ESPEnabled = true,
    CurrentColor = Color3.fromRGB(0, 210, 255)
}

local UI_Visible = true
local Camera = workspace.CurrentCamera or workspace:FindFirstChildOfClass("Camera")
local ScreenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
local MenuPosition = Vector2.new(100, 150)
local ESPObjects = {}
local DrawElements = {}

if _G.BereHubCleanup then _G.BereHubCleanup() end

---------------------------------------------------------
-- PRIMITIVE DRAWING UTILITY WRAPPERS
---------------------------------------------------------
local function NewLine(color, thickness)
    local l = Drawing.new("Line")
    l.Color = color
    l.Thickness = thickness or 1
    l.Transparency = 1
    l.Visible = false
    table.insert(DrawElements, l)
    return l
end

local function NewSquare(color, filled)
    local s = Drawing.new("Square")
    s.Color = color
    s.Filled = filled or false
    s.Thickness = 1
    s.Size = Vector2.new(0, 0)
    s.Position = Vector2.new(0, 0)
    s.Transparency = 1
    s.Visible = false
    table.insert(DrawElements, s)
    return s
end

local function NewText(text, size, color, center)
    local t = Drawing.new("Text")
    t.Text = text
    t.Size = size or 13
    t.Color = color or Color3.fromRGB(255, 255, 255)
    t.Center = center or false
    t.Outline = true
    t.Position = Vector2.new(0, 0)
    t.Transparency = 1
    t.Visible = false
    table.insert(DrawElements, t)
    return t
end

---------------------------------------------------------
-- NATIVE INTERFACE CANVAS ASSEMBLY
---------------------------------------------------------
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1.5
FOVCircle.NumSides = 64
FOVCircle.Radius = Settings.FOV
FOVCircle.Filled = false
FOVCircle.Transparency = 1
FOVCircle.Color = Settings.CurrentColor
FOVCircle.Visible = Settings.FOVEnabled

local Background = NewSquare(Color3.fromRGB(12, 13, 19), true)
Background.Size = Vector2.new(340, 240)

local Header = NewSquare(Color3.fromRGB(18, 20, 28), true)
Header.Size = Vector2.new(340, 30)

local TitleText = NewText("BERE HUB // PURE RENDER CONSOLE", 13, Color3.fromRGB(255, 255, 255))
local CloseBtn = NewText("[X]", 13, Color3.fromRGB(255, 80, 80), true)
local MinimizeBtn = NewText("[-]", 13, Color3.fromRGB(160, 170, 190), true)

local MobileBtn = NewSquare(Color3.fromRGB(18, 20, 28), true)
MobileBtn.Size = Vector2.new(65, 25)
MobileBtn.Position = Vector2.new(20, 120)
local MobileTxt = NewText("[MENU]", 12, Color3.fromRGB(255, 255, 255), true)

local OptionRegistry = {
    {Text = "Target Lock Engine", Type = "Toggle", Key = "TargetLock"},
    {Text = "Visibility Geometry Check", Type = "Toggle", Key = "VisibilityCheck"},
    {Text = "Render Calibration FOV", Type = "Toggle", Key = "FOVEnabled"},
    {Text = "Adjust FOV Range (Left/Right Keys)", Type = "Slider", Key = "FOV"},
    {Text = "Active Player ESP Box", Type = "Toggle", Key = "ESPEnabled"}
}

for i, opt in ipairs(OptionRegistry) do
    opt.TextLabel = NewText(opt.Text, 13, Color3.fromRGB(230, 230, 230))
    if opt.Type == "Toggle" then
        opt.StatusLabel = NewText("OFF", 13, Color3.fromRGB(255, 80, 80))
    else
        opt.StatusLabel = NewText(tostring(Settings[opt.Key]), 13, Settings.CurrentColor)
    end
end

local function RenderInterfaceStructure()
    Camera = workspace.CurrentCamera or workspace:FindFirstChildOfClass("Camera")
    if not Camera then return end
    
    ScreenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    FOVCircle.Position = ScreenCenter
    FOVCircle.Radius = Settings.FOV
    FOVCircle.Color = Settings.CurrentColor
    FOVCircle.Visible = Settings.FOVEnabled and UI_Visible

    Background.Position = MenuPosition
    Background.Visible = UI_Visible

    Header.Position = MenuPosition
    Header.Visible = UI_Visible

    TitleText.Position = MenuPosition + Vector2.new(10, 8)
    TitleText.Visible = UI_Visible
    
    CloseBtn.Position = MenuPosition + Vector2.new(320, 8)
    CloseBtn.Visible = UI_Visible

    MinimizeBtn.Position = MenuPosition + Vector2.new(295, 8)
    MinimizeBtn.Visible = UI_Visible
    
    MobileBtn.Visible = not UI_Visible
    MobileTxt.Position = MobileBtn.Position + Vector2.new(32, 5)
    MobileTxt.Visible = not UI_Visible

    for i, opt in ipairs(OptionRegistry) do
        local rowY = MenuPosition.Y + 35 + (i * 32)
        opt.TextLabel.Position = Vector2.new(MenuPosition.X + 15, rowY)
        opt.TextLabel.Visible = UI_Visible
        
        opt.StatusLabel.Position = Vector2.new(MenuPosition.X + 280, rowY)
        opt.StatusLabel.Visible = UI_Visible
        if opt.Type == "Toggle" then
            opt.StatusLabel.Text = Settings[opt.Key] and "ON" or "OFF"
            opt.StatusLabel.Color = Settings[opt.Key] and Settings.CurrentColor or Color3.fromRGB(255, 80, 80)
        else
            opt.StatusLabel.Text = tostring(Settings[opt.Key])
            opt.StatusLabel.Color = Settings.CurrentColor
        end
    end
end

local function KillPermanently()
    if _G.BereHubCleanup then _G.BereHubCleanup() end
    UI_Visible = false
    Background.Visible = false
    Header.Visible = false
    TitleText.Visible = false
    CloseBtn.Visible = false
    MinimizeBtn.Visible = false
    MobileBtn.Visible = false
    MobileTxt.Visible = false
    FOVCircle.Visible = false
    for _, opt in ipairs(OptionRegistry) do
        opt.TextLabel.Visible = false
        opt.StatusLabel.Visible = false
    end
end

---------------------------------------------------------
-- CONTROL & INTERACTION HOOKS
---------------------------------------------------------
local IsDragging = false
local DragOffset = Vector2.new(0, 0)

UserInputService.InputBegan:Connect(function(input, processed)
    if input.KeyCode == Enum.KeyCode.RightControl then
        UI_Visible = not UI_Visible
        RenderInterfaceStructure()
    end
    
    if not UI_Visible then
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local mPos = UserInputService:GetMouseLocation()
            if mPos.X >= MobileBtn.Position.X and mPos.X <= MobileBtn.Position.X + MobileBtn.Size.X and mPos.Y >= MobileBtn.Position.Y and mPos.Y <= MobileBtn.Position.Y + MobileBtn.Size.Y then
                UI_Visible = true
                RenderInterfaceStructure()
            end
        end
        return
    end

    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        local mousePos = UserInputService:GetMouseLocation()
        
        if mousePos.X >= CloseBtn.Position.X - 15 and mousePos.X <= CloseBtn.Position.X + 15 and mousePos.Y >= CloseBtn.Position.Y - 5 and mousePos.Y <= CloseBtn.Position.Y + 20 then
            KillPermanently()
            return
        end

        if mousePos.X >= MinimizeBtn.Position.X - 15 and mousePos.X <= MinimizeBtn.Position.X + 15 and mousePos.Y >= MinimizeBtn.Position.Y - 5 and mousePos.Y <= MinimizeBtn.Position.Y + 20 then
            UI_Visible = false
            RenderInterfaceStructure()
            return
        end

        if mousePos.X >= Header.Position.X and mousePos.X <= Header.Position.X + Header.Size.X and mousePos.Y >= Header.Position.Y and mousePos.Y <= Header.Position.Y + Header.Size.Y then
            IsDragging = true
            DragOffset = MenuPosition - mousePos
        end

        for i, opt in ipairs(OptionRegistry) do
            local rowY = MenuPosition.Y + 35 + (i * 32)
            if mousePos.X >= MenuPosition.X and mousePos.X <= MenuPosition.X + 340 and mousePos.Y >= rowY and mousePos.Y <= rowY + 25 then
                if opt.Type == "Toggle" then
                    Settings[opt.Key] = not Settings[opt.Key]
                end
                RenderInterfaceStructure()
            end
        end
    end

    if input.KeyCode == Enum.KeyCode.Left then
        Settings.FOV = math.clamp(Settings.FOV - 10, 30, 400)
        RenderInterfaceStructure()
    elseif input.KeyCode == Enum.KeyCode.Right then
        Settings.FOV = math.clamp(Settings.FOV + 10, 30, 400)
        RenderInterfaceStructure()
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if IsDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        MenuPosition = UserInputService:GetMouseLocation() + DragOffset
        RenderInterfaceStructure()
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        IsDragging = false
    end
end)

---------------------------------------------------------
-- ESP AND TARGETING RENDERING SYSTEM
---------------------------------------------------------
local function CreateESP(player)
    if ESPObjects[player] then return end
    local Box = Drawing.new("Square")
    Box.Thickness = 1
    Box.Filled = false
    Box.Transparency = 1
    local Text = Drawing.new("Text")
    Text.Size = 13
    Text.Center = true
    Text.Outline = true
    Text.Transparency = 1
    ESPObjects[player] = {Box = Box, Text = Text}
end

local function RemoveESP(player)
    if ESPObjects[player] then
        pcall(function() ESPObjects[player].Box:Remove() end)
        pcall(function() ESPObjects[player].Text:Remove() end)
        ESPObjects[player] = nil
    end
end

for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then CreateESP(p) end end
Players.PlayerAdded:Connect(function(p) if p ~= LocalPlayer then CreateESP(p) end end)
Players.PlayerRemoving:Connect(RemoveESP)

local function RunRaycastCheck(character, targetPart)
    Camera = workspace.CurrentCamera or workspace:FindFirstChildOfClass("Camera")
    if not Camera then return false end
    
    local RayParams = RaycastParams.new()
    RayParams.FilterType = Enum.RaycastFilterType.Exclude
    RayParams.FilterDescendantsInstances = {LocalPlayer.Character, character}
    
    local StructuralResult = workspace:Raycast(Camera.CFrame.Position, targetPart.Position - Camera.CFrame.Position, RayParams)
    return StructuralResult == nil
end

local function GetTarget()
    Camera = workspace.CurrentCamera or workspace:FindFirstChildOfClass("Camera")
    if not Camera then return nil end
    local SelectedCandidate = nil
    local ClosestDistance = Settings.FOV

    for _, player in ipairs(Players:GetPlayers()) do
        local character = player.Character
        if character and character ~= LocalPlayer.Character then
            local AimPart = character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
            local Humanoid = character:FindFirstChildOfClass("Humanoid")
            
            if AimPart and Humanoid and Humanoid.Health > 0 then
                local ScalePoint, TrackedOnScreen = Camera:WorldToViewportPoint(AimPart.Position)
                if TrackedOnScreen or not Settings.VisibilityCheck then
                    if not Settings.VisibilityCheck or RunRaycastCheck(character, AimPart) then
                        local VectorOffset = (Vector2.new(ScalePoint.X, ScalePoint.Y) - ScreenCenter).Magnitude
                        if VectorOffset < ClosestDistance then
                            ClosestDistance = VectorOffset
                            SelectedCandidate = character
                        end
                    end
                end
            end
        end
    end
    return SelectedCandidate
end

local MasterConnection = RunService.RenderStepped:Connect(function(dt)
    Camera = workspace.CurrentCamera or workspace:FindFirstChildOfClass("Camera")
    if not Camera then return end

    if Settings.TargetLock then
        local target = GetTarget()
        if target and target:FindFirstChild("Head") then
            -- Smoothed framing adjustment
            local TargetCFrame = CFrame.lookAt(Camera.CFrame.Position, target.Head.Position)
            Camera.CFrame = Camera.CFrame:Lerp(TargetCFrame, math.clamp(dt / Settings.Smoothness, 0, 1))
        end
    end

    for player, graphic in pairs(ESPObjects) do
        local character = player.Character
        if Settings.ESPEnabled and character and character:FindFirstChild("HumanoidRootPart") and character:FindFirstChildOfClass("Humanoid") and character:FindFirstChildOfClass("Humanoid").Health > 0 then
            local RootPart = character.HumanoidRootPart
            local PosVector, OnScreenProjection = Camera:WorldToViewportPoint(RootPart.Position)
            
            if OnScreenProjection then
                -- Direct scaling adjustment relative to distance
                local Distance = PosVector.Z
                local BoxWidth = math.clamp(500 / Distance, 10, 150)
                local BoxHeight = math.clamp(750 / Distance, 15, 220)
                
                graphic.Box.Size = Vector2.new(BoxWidth, BoxHeight)
                graphic.Box.Position = Vector2.new(PosVector.X - BoxWidth / 2, PosVector.Y - BoxHeight / 2)
                graphic.Box.Color = Settings.CurrentColor
                graphic.Box.Visible = true

                graphic.Text.Text = string.format("%s [%dM]", player.Name, math.floor(Distance))
                graphic.Text.Position = Vector2.new(PosVector.X, (PosVector.Y - BoxHeight / 2) - 16)
                graphic.Text.Color = Color3.fromRGB(255, 255, 255)
                graphic.Text.Visible = true
            else
                graphic.Box.Visible = false; graphic.Text.Visible = false
            end
        else
            graphic.Box.Visible = false; graphic.Text.Visible = false
        end
    end
end)

_G.BereHubCleanup = function()
    MasterConnection:Disconnect()
    pcall(function() FOVCircle:Remove() end)
    for _, el in pairs(DrawElements) do pcall(function() el:Remove() end) end
    for _, asset in pairs(ESPObjects) do
        pcall(function() asset.Box:Remove() end)
        pcall(function() asset.Text:Remove() end)
    end
end

RenderInterfaceStructure()
