--// 2. Dragging Logic (Strictly limited to TopBar)
local dragging, dragInput, dragStart, startPos
TopBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = MainFrame.Position
		
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

TopBar.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		local delta = input.Position - dragStart
		MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

--// 3. System Target Search Math
local function IsVisible(targetPart)
	if not Config.WallCheck then return true end
	local castPoints = {Camera.CFrame.Position, targetPart.Position}
	local ignoreList = {LocalPlayer.Character, targetPart.Parent}
	local parts = Camera:GetPartsObscuringTarget(castPoints, ignoreList)
	return #parts == 0
end

local function GetClosestTargetInFOV()
	local closestTarget = nil
	local shortestDistance = Config.FOVRadius

	-- Iterate through all potential character targets across the Workspace
	for _, obj in ipairs(Workspace:GetDescendants()) do
		local humanoid = obj:FindFirstChildOfClass("Humanoid")
		local head = obj:FindFirstChild(Config.TargetPart)
		
		-- Filter out local player, dead targets, and ensuring components exist
		if humanoid and head and obj ~= LocalPlayer.Character and humanoid.Health > 0 then
			local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
			
			if onScreen then
				local mousePos = Vector2.new(Mouse.X, Mouse.Y)
				local targetPos2D = Vector2.new(screenPos.X, screenPos.Y)
				local distance = (targetPos2D - mousePos).Magnitude
				
				if distance < shortestDistance then
					if IsVisible(head) then
						shortestDistance = distance
						closestTarget = head
					end
				end
			end
		end
	end
	return closestTarget
end

--// 4. Input Listeners
UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	
	-- Handle UI open/close keybind
	if input.KeyCode == Config.Keybind then
		UIHidden = not UIHidden
		MainFrame.Visible = not UIHidden
		FOVCircle.Visible = (not UIHidden)
	end
	
	-- Handle Aim Activation
	if input.UserInputType == Config.LockKey then
		IsLocking = true
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Config.LockKey then
		IsLocking = false
		CurrentTarget = nil
		TargetHighlight.Enabled = false
	end
end)

--// 5. Execution Frame Loop
RunService.RenderStepped:Connect(function()
	-- Dynamic center-tracking for the FOV frame
	FOVCircle.Position = UDim2.new(0, Mouse.X, 0, Mouse.Y)
	
	if not Config.Enabled then 
		TargetHighlight.Enabled = false
		return 
	end
	
	if IsLocking then
		-- Maintain lock or find a valid tracking point within circle bounds
		if not CurrentTarget or not CurrentTarget.Parent or not CurrentTarget.Parent:FindFirstChildOfClass("Humanoid") or CurrentTarget.Parent:FindFirstChildOfClass("Humanoid").Health <= 0 then
			CurrentTarget = GetClosestTargetInFOV()
		end
		
		if CurrentTarget then
			-- Engage highlight engine tracking across environmental objects
			TargetHighlight.Adornee = CurrentTarget.Parent
			TargetHighlight.Enabled = true
			
			-- Smooth camera matrix transformation targeting the rig/player head
			local targetLookCFrame = CFrame.new(Camera.CFrame.Position, CurrentTarget.Position)
			Camera.CFrame = Camera.CFrame:Lerp(targetLookCFrame, Config.Smoothness)
		else
			TargetHighlight.Enabled = false
		end
	else
		TargetHighlight.Enabled = false
	end
end)
