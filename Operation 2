local function GetClosestHostileToMouse()
    local Target = nil
    local Dist = math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            -- Verify team status to prevent team-killing
            local IsHostile = true
            if p.Team and LocalPlayer.Team and p.Team == LocalPlayer.Team then
                IsHostile = false
            end
            
            if IsHostile then
                local Hum = p.Character:FindFirstChildOfClass("Humanoid")
                if Hum and Hum.Health > 0 then
                    local ScreenPos, OnScreen = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
                    if OnScreen then
                        local MouseDist = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(ScreenPos.X, ScreenPos.Y)).Magnitude
                        if MouseDist < Dist then
                            Target = p.Character:FindFirstChild("Head") or p.Character.HumanoidRootPart
                            Dist = MouseDist
                        end
                    end
                end
            end
        end
    end
    return Target
end

-- Active Aimlock Tracking Loop
RunService.RenderStepped:Connect(function()
    if States.Aimlock then
        local LockTarget = GetClosestHostileToMouse()
        if LockTarget then
            local CurrentLook = Camera.CFrame
            local TargetLook = CFrame.new(Camera.CFrame.Position, LockTarget.Position)
            Camera.CFrame = CurrentLook:Lerp(TargetLook, States.AimlockSmoothness)
        end
    end
end)

-- Silent Aim Interceptor Hook
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(Self, ...)
    local Method = getnamecallmethod()
    local Args = {...}
    
    if Method == "FireServer" and States.SilentAim then
        -- Intercept generic bullet fire remote pathways to redirect hits to target head
        if Self.Name == "Shoot" or Self.Name == "Hit" or Self.Name == "Fire" then
            local LockTarget = GetClosestHostileToMouse()
            if LockTarget then
                -- Spoof hit position vectors and targets inside remote arguments
                for i, arg in ipairs(Args) do
                    if typeof(arg) == "Vector3" then
                        Args[i] = LockTarget.Position
                    elseif typeof(arg) == "Instance" and (arg:IsA("BasePart") or arg:IsA("Model")) then
                        Args[i] = LockTarget
                    end
                end
                return OldNamecall(Self, unpack(Args))
            end
        end
    end
    return OldNamecall(Self, ...)
end))

