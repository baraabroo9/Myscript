local RawMeta = getrawmetatable(game)
if RawMeta and setreadonly then
    setreadonly(RawMeta, false)
    local OldIndex = RawMeta.__index
    local OldNamecall = RawMeta.__namecall
    
    -- Spoofing properties to dodge client checks
    RawMeta.__index = newcclosure(function(Self, Key)
        if not checkcaller() then
            if Self:IsA("Humanoid") then
                if Key == "WalkSpeed" and States.BypassWalkspeed then
                    return 16 -- Report vanilla speed back to client scripts
                end
            end
            if States.AntiKnock then
                if Self:IsA("BodyVelocity") or Self:IsA("LinearVelocity") or Self:IsA("VectorForce") then
                    if Key == "Velocity" or Key == "AssemblyLinearVelocity" then
                        return Vector3.zero
                    end
                end
            end
        end
        return OldIndex(Self, Key)
    end)
    
    -- Suppress flag triggers & network telemetry
    RawMeta.__namecall = newcclosure(function(Self, ...)
        local Method = getnamecallmethod()
        if not checkcaller() then
            if Method == "FireServer" then
                local Name = Self.Name:lower()
                if Name:find("cheat") or Name:find("detection") or Name:find("ban") or Name:find("kick") or Name:find("teleport") then
                    return nil -- Intercept and block client flags
                end
            end
        end
        return OldNamecall(Self, ...)
    end)
    
    setreadonly(RawMeta, true)
end

