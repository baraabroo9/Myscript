    local indicator = Instance.new("Frame")
    indicator.Size = UDim2.new(0, 12, 0, 12)
    indicator.Position = UDim2.new(1, -22, 0.5, -6)
    indicator.BackgroundColor3 = States[configKey] and Color3.fromRGB(138, 43, 226) or Color3.fromRGB(30, 26, 38)
    indicator.Parent = btn
    local ticr = Instance.new("UICorner") ticr.CornerRadius = UDim.new(1, 0) ticr.Parent = indicator

    btn.MouseButton1Click:Connect(function()
        States[configKey] = not States[configKey]
        indicator.BackgroundColor3 = States[configKey] and Color3.fromRGB(138, 43, 226) or Color3.fromRGB(30, 26, 38)
    end)
end

