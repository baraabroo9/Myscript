local ActiveObjectiveDrawings = {}

local function CreateObjectiveESP(Instance, DisplayName, ThemeColor)
    if ActiveObjectiveDrawings[Instance] then return end
    
    local ESP = {
        Text = Drawing.new("Text")
    }
    ActiveObjectiveDrawings[Instance] = ESP
    
    ESP.Text.Size = 11
    ESP.Text.Center = true
    ESP.Text.Outline = true
    ESP.Text.Color = ThemeColor
    ESP.Text.Visible = false
    
    local Connection
    Connection = RunService.RenderStepped:Connect(function()
        if not Instance or not Instance.Parent or not States.ObjectiveESP then
            ESP.Text.Visible = false
            if not Instance.Parent then
                ESP.Text:Destroy()
                ActiveObjectiveDrawings[Instance] = nil
                Connection:Disconnect()
            end
            return
        end
        
        local Part = Instance:IsA("BasePart") and Instance or Instance:FindFirstChildOfClass("BasePart") or Instance.PrimaryPart
        if Part then
            local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Part.Position)
            if OnScreen then
                local Distance = math.floor((RootPart.Position - Part.Position).Magnitude)
                ESP.Text.Position = Vector2.new(ScreenPos.X, ScreenPos.Y)
                ESP.Text.Text = string.format("[%s (%dM)]", DisplayName, Distance)
                ESP.Text.Visible = true
            else
                ESP.Text.Visible = false
            end
        else
            ESP.Text.Visible = false
        end
    end)
end

