local TargetDrawings = {}

local function CreateTacticalESP(TargetPlayer)
    if TargetPlayer == LocalPlayer then return end
    
    local ESP = {
        BoxOutline = Drawing.new("Square"),
        Box = Drawing.new("Square"),
        Tracer = Drawing.new("Line"),
        HealthOutline = Drawing.new("Line"),
        HealthBar = Drawing.new("Line"),
        HeadCircle = Drawing.new("Circle"),
        Label = Drawing.new("Text")
    }
    TargetDrawings[TargetPlayer] = ESP
    
    -- Design Config
    ESP.BoxOutline.Thickness = 3
    ESP.BoxOutline.Color = Color3.fromRGB(0, 0, 0)
    ESP.BoxOutline.Filled = false
    ESP.Box.Thickness = 1.5
    ESP.Box.Filled = false
    
    ESP.Tracer.Thickness = 1.2
    
    ESP.HealthOutline.Thickness = 3
    ESP.HealthOutline.Color = Color3.fromRGB(0, 0, 0)
    ESP.HealthBar.Thickness = 1.5
    
    ESP.HeadCircle.Radius = 4
    ESP.HeadCircle.Filled = true
    ESP.HeadCircle.Color = Color3.fromRGB(255, 30, 30)
    
    ESP.Label.Size = 11
    ESP.Label.Center = true
    ESP.Label.Outline = true
    ESP.Label.Color = Color3.fromRGB(255, 255, 255)
    
    local Connection
    Connection = RunService.RenderStepped:Connect(function()
        local Char = TargetPlayer.Character
        local Root = Char and Char:FindFirstChild("HumanoidRootPart")
        local Hum = Char and Char:FindFirstChildOfClass("Humanoid")
        
        if not Char or not Root or not Hum or not States.MasterESP or Hum.Health <= 0 then
            for _, draw in pairs(ESP) do draw.Visible = false end
            if not TargetPlayer.Parent then
                for _, draw in pairs(ESP) do draw:Destroy() end
                TargetDrawings[TargetPlayer] = nil
                Connection:Disconnect()
            end
            return
        end
        
        local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Root.Position)
        
        if OnScreen then
            local TopPos = Camera:WorldToViewportPoint(Root.Position + Vector3.new(0, 3, 0))
            local BottomPos = Camera:WorldToViewportPoint(Root.Position - Vector3.new(0, 3.5, 0))
            local Height = math.abs(TopPos.Y - BottomPos.Y)
            local Width = Height / 1.5
            
            -- Hostile vs Ally Check for Operation: One Team Layouts
            local IsHostile = true
            if TargetPlayer.Team and LocalPlayer.Team and TargetPlayer.Team == LocalPlayer.Team then
                IsHostile = false
            end
            
            local ColorTheme = IsHostile and Color3.fromRGB(255, 30, 70) or Color3.fromRGB(0, 230, 118)
            
            -- Struct Box
            if States.BoxESP then
                ESP.BoxOutline.Size = Vector2.new(Width, Height)
                ESP.BoxOutline.Position = Vector2.new(ScreenPos.X - Width/2, ScreenPos.Y - Height/2)
                ESP.BoxOutline.Visible = true
                
                ESP.Box.Size = Vector2.new(Width, Height)
                ESP.Box.Position = ESP.BoxOutline.Position
                ESP.Box.Color = ColorTheme
                ESP.Box.Visible = true
            else
                ESP.BoxOutline.Visible = false
                ESP.Box.Visible = false
            end
            
            -- Directional Lines
            if States.TracerESP then
                ESP.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                ESP.Tracer.To = Vector2.new(ScreenPos.X, ScreenPos.Y + Height/2)
                ESP.Tracer.Color = ColorTheme
                ESP.Tracer.Visible = true
            else
                ESP.Tracer.Visible = false
            end
            
            -- Tactical Health Metric
            if States.HealthBar then
                local HealthPct = math.clamp(Hum.Health / Hum.MaxHealth, 0, 1)
                local BarHeight = Height * HealthPct
                
                ESP.HealthOutline.From = Vector2.new(ScreenPos.X - Width/2 - 6, ScreenPos.Y + Height/2)
                ESP.HealthOutline.To = Vector2.new(ScreenPos.X - Width/2 - 6, ScreenPos.Y - Height/2)
                ESP.HealthOutline.Visible = true
                
                ESP.HealthBar.From = Vector2.new(ScreenPos.X - Width/2 - 6, ScreenPos.Y + Height/2)
                ESP.HealthBar.To = Vector2.new(ScreenPos.X - Width/2 - 6, (ScreenPos.Y + Height/2) - BarHeight)
                ESP.HealthBar.Color = Color3.fromHSV(HealthPct * 0.35, 1, 1)
                ESP.HealthBar.Visible = true
            else
                ESP.HealthOutline.Visible = false
                ESP.HealthBar.Visible = false
            end
            
            -- Target Marker
            local Head = Char:FindFirstChild("Head")
            if States.HeadDot and Head then
                local HeadPos, HeadOnScreen = Camera:WorldToViewportPoint(Head.Position)
                if HeadOnScreen then
                    ESP.HeadCircle.Position = Vector2.new(HeadPos.X, HeadPos.Y)
                    ESP.HeadCircle.Visible = true
                else
                    ESP.HeadCircle.Visible = false
                end
            else
                ESP.HeadCircle.Visible = false
            end
            
            -- Dynamic Data Strings
            local Distance = math.floor((RootPart.Position - Root.Position).Magnitude)
            ESP.Label.Position = Vector2.new(ScreenPos.X, ScreenPos.Y - Height/2 - 16)
            ESP.Label.Text = string.format("%s - %dM", TargetPlayer.DisplayName:upper(), Distance)
            ESP.Label.Visible = true
        else
            for _, draw in pairs(ESP) do draw.Visible = false end
        end
    end)
end

