-- [[ UI COMPONENT FACTORIES ]] --
local function createToggle(name, configKey)
    local Container = Instance.new("Frame")
    Container.Size = UDim2.new(1, 0, 0, 35)
    Container.BackgroundTransparency = 1
    Container.Parent = ContentList

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0.7, 0, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = name
    Label.TextColor3 = Color3.fromRGB(210, 210, 215)
    Label.Font = Enum.Font.GothamMedium
    Label.TextSize = 14
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = Container

    local Button = Instance.new("TextButton")
    Button.Size = UDim2.new(0, 46, 0, 24)
    Button.Position = UDim2.new(1, -46, 0.5, -12)
    Button.BackgroundColor3 = Settings[configKey] and Color3.fromRGB(130, 80, 220) or Color3.fromRGB(40, 38, 45)
    Button.Text = ""
    Button.Parent = Container

    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 12)
    BtnCorner.Parent = Button

    Button.MouseButton1Click:Connect(function()
        Settings[configKey] = not Settings[configKey]
        Button.BackgroundColor3 = Settings[configKey] and Color3.fromRGB(130, 80, 220) or Color3.fromRGB(40, 38, 45)
        saveSettings()
    end)
end

local function createSlider(name, configKey, min, max)
    local Container = Instance.new("Frame")
    Container.Size = UDim2.new(1, 0, 0, 50)
    Container.BackgroundTransparency = 1
    Container.Parent = ContentList

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, 0, 0, 20)
    Label.BackgroundTransparency = 1
    Label.Text = name .. ": " .. tostring(Settings[configKey])
    Label.TextColor3 = Color3.fromRGB(180, 180, 185)
    Label.Font = Enum.Font.GothamMedium
    Label.TextSize = 13
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = Container

    local SlideTrack = Instance.new("TextButton")
    SlideTrack.Size = UDim2.new(1, 0, 0, 8)
    SlideTrack.Position = UDim2.new(0, 0, 0, 28)
    SlideTrack.BackgroundColor3 = Color3.fromRGB(40, 38, 45)
    SlideTrack.Text = ""
    SlideTrack.Parent = Container

    local TrackCorner = Instance.new("UICorner")
    TrackCorner.CornerRadius = UDim.new(0, 4)
    TrackCorner.Parent = SlideTrack

    local SlideFill = Instance.new("Frame")
    local initPercent = (Settings[configKey] - min) / (max - min)
    SlideFill.Size = UDim2.new(initPercent, 0, 1, 0)
    SlideFill.BackgroundColor3 = Color3.fromRGB(130, 80, 220)
    SlideFill.BorderSizePixel = 0
    SlideFill.Parent = SlideTrack
    
    local FillCorner = Instance.new("UICorner")
    FillCorner.CornerRadius = UDim.new(0, 4)
    FillCorner.Parent = SlideFill

    local function updateSlider(inputX)
        local percentage = math.clamp((inputX - SlideTrack.AbsolutePosition.X) / SlideTrack.AbsoluteSize.X, 0, 1)
        SlideFill.Size = UDim2.new(percentage, 0, 1, 0)
        local value = math.floor(min + (percentage * (max - min)))
        Label.Text = name .. ": " .. tostring(value)
        Settings[configKey] = value
        saveSettings()
    end

    SlideTrack.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            updateSlider(input.Position.X)
            local moveCon
            moveCon = UserInputService.InputChanged:Connect(function(changedInput)
                if changedInput.UserInputType == Enum.UserInputType.MouseMovement or changedInput.UserInputType == Enum.UserInputType.Touch then
                    updateSlider(changedInput.Position.X)
                end
            end)
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    moveCon:Disconnect()
                end
            end)
        end
    end)
end

-- [[ CORE SYSTEM INJECTION ]] --
local function runReachLogic(partName, toggleState, sliderVal)
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetPart = player.Character:FindFirstChild(partName)
            if targetPart and targetPart:IsA("BasePart") then
                if toggleState and sliderVal > 1 then
                    targetPart.Size = Vector3.new(sliderVal, sliderVal, sliderVal)
                    targetPart.Transparency = Settings.ReachTransparency / 10
                    targetPart.CanCollide = false
                else
                    if targetPart.Name == "Head" then
                        targetPart.Size = Vector3.new(2, 1, 1)
                    else
                        targetPart.Size = Vector3.new(1, 2, 1)
                    end
                    targetPart.Transparency = 0
                end
            end
        end
    end
end

RunService.RenderStepped:Connect(function()
    runReachLogic("Head", Settings.HeadToggle, Settings.HeadReach)
    
    runReachLogic("UpperTorso", Settings.ChestToggle, Settings.ChestReach)
    runReachLogic("Torso", Settings.ChestToggle, Settings.ChestReach)
    
    runReachLogic("LeftHand", Settings.HandsToggle, Settings.HandsReach)
    runReachLogic("RightHand", Settings.HandsToggle, Settings.HandsReach)
    runReachLogic("LeftArm", Settings.HandsToggle, Settings.HandsReach)
    runReachLogic("RightArm", Settings.HandsToggle, Settings.HandsReach)
    
    runReachLogic("LeftFoot", Settings.LegsToggle, Settings.LegsReach)
    runReachLogic("RightFoot", Settings.LegsToggle, Settings.LegsReach)
    runReachLogic("LeftLeg", Settings.LegsToggle, Settings.LegsReach)
    runReachLogic("RightLeg", Settings.LegsToggle, Settings.LegsReach)

    if Settings.InfiniteStamina then
        local char = LocalPlayer.Character
        if char then
            local stamina = char:FindFirstChild("Stamina") or char:FindFirstChild("Energy") or LocalPlayer:FindFirstChild("Stamina")
            if stamina and (stamina:IsA("NumberValue") or stamina:IsA("IntValue")) then
                stamina.Value = 100
            end
        end
    end
end)

