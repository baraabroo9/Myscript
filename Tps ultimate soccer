-- [[ CONFIGURATION SYSTEM ]] --
local function saveSettings()
    if writefile then
        local success, encoded = pcall(HttpService.JSONEncode, HttpService, Settings)
        if success then writefile(CONFIG_FILE, encoded) end
    end
end

local function loadSettings()
    if readfile and isfile and isfile(CONFIG_FILE) then
        local success, decoded = pcall(HttpService.JSONDecode, HttpService, readfile(CONFIG_FILE))
        if success then
            for k, v in pairs(decoded) do
                Settings[k] = v
            end
        end
    end
end

