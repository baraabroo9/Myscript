local joystickActive = false
local joystickCenter = Vector2.new(s(100), s(100))
local tripleTapCount = 0
local tripleTapTime = 0

joystickFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        joystickActive = true
        -- triple tap detection
        local now = tick()
        if now - tripleTapTime < 0.5 then
            tripleTapCount = tripleTapCount + 1
        else
            tripleTapCount = 1
        end
        tripleTapTime = now
        if tripleTapCount >= 3 then
            tripleTapCount = 0
            screenGui.Enabled = not screenGui.Enabled
        end
    end
end)
joystickFrame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        joystickActive = false
        knob.Position = UDim2.new(0.5, -s(35), 0.5, -s(35))
        _G.joystickX = 0
        _G.joystickY = 0
    end
end)
joystickFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch and joystickActive then
        local pos = input.Position
        local rel = pos - joystickFrame.AbsolutePosition - joystickCenter
        local maxDist = s(80)
        local dist = rel.Magnitude
        if dist > maxDist then rel = rel / dist * maxDist end
        knob.Position = UDim2.new(0.5, -s(35) + rel.X, 0.5, -s(35) + rel.Y)
        _G.joystickX = math.clamp(rel.X / maxDist, -1, 1)
        _G.joystickY = math.clamp(-rel.Y / maxDist, -1, 1)
    end
end)

