local function makeWinBtn(text, color, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, s(32), 0, s(32))
    btn.Position = UDim2.new(1, -s(120) - (text=="✕" and 0 or text=="□" and s(40) or s(80)), 0.5, -s(16))
    btn.BackgroundColor3 = Color3.fromRGB(0,0,0,0.3)
    btn.BorderSizePixel = 0
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(200,200,200)
    btn.TextSize = s(18)
    btn.Font = Enum.Font.GothamBold
    btn.Parent = titleBar
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, s(6))
    btnCorner.Parent = btn
    btn.MouseButton1Click:Connect(callback)
    return btn
end

local minimized = false
local function minimize()
    minimized = not minimized
    if minimized then
        mainFrame:TweenSize(UDim2.new(0, s(200), 0, s(52)), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.3, true)
        mainFrame:TweenPosition(UDim2.new(0.5, -s(100), 0, s(10)), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.3, true)
        -- hide body
        bodyFrame.Visible = false
    else
        mainFrame:TweenSize(UDim2.new(0, s(820), 0, s(620)), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.3, true)
        mainFrame:TweenPosition(UDim2.new(0.5, -s(410), 0.5, -s(310)), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.3, true)
        bodyFrame.Visible = true
    end
end

