local function executeScript()
    local code = editorBox.Text
    if #code < 5 then consoleText.Text = "> [Error] Empty script." return end
    local success, err = pcall(function() loadstring(code)() end)
    if success then
        consoleText.Text = "> [Success] Script executed."
        statusLed.BackgroundColor3 = Color3.fromRGB(85,255,85)
        statusText.Text = "Running"
    else
        consoleText.Text = "> [Error] " .. tostring(err)
        statusLed.BackgroundColor3 = Color3.fromRGB(255,85,85)
        statusText.Text = "Error"
    end
end

