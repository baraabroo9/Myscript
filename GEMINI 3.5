--> Metatable Security & Anti-Knockback Hook <--
local mt = getrawmetatable(game)
if mt and setreadonly then
    setreadonly(mt, false)
    local oldIndex = mt.__index
    local oldNewIndex = mt.__newindex
    
    mt.__newindex = newcclosure(function(self, key, value)
        if not checkcaller() and Features.AntiKnock and self:IsA("BodyVelocity") or self:IsA("LinearVelocity") then
            return -- Block external forces from setting velocity objects
        end
        if not checkcaller() and Features.AntiKnock and self.Name == "HumanoidRootPart" and key == "Velocity" then
            return -- Block direct velocity writes to root
        end
        return oldNewIndex(self, key, value)
    end)
    setreadonly(mt, true)
end

--------------------------------------------------------------------------------
-- AUTO-PARRY ENGINE (DIAGNOSTIC DETECTION)
--------------------------------------------------------------------------------
local function triggerParry()
    local tool = playerCharacter:FindFirstChildOfClass("Tool")
    if tool then
        -- Automatically try both VirtualInput and Direct Activation to guarantee execution
        tool:Activate()
        local blockRemote = tool:FindFirstChild("Block") or tool:FindFirstChild("Parry") or tool:FindFirstChild("Remote")
        if blockRemote and blockRemote:IsA("RemoteEvent") then
            blockRemote:FireServer(true)
        end
    end
end

RunService.Heartbeat:Connect(function()
    if not Features.AutoParry or not playerHumanoidRootPart then return end
    
    for _, enemy in ipairs(Players:GetPlayers()) do
        if enemy ~= player and enemy.Character and enemy.Character:FindFirstChild("HumanoidRootPart") then
            local enemyRoot = enemy.Character.HumanoidRootPart
            local distance = (playerHumanoidRootPart.Position - enemyRoot.Position).Magnitude
            
            -- Detect proximity and attack animations
            if distance < 12 then
                local enemyHumanoid = enemy.Character:FindFirstChildOfClass("Humanoid")
                if enemyHumanoid then
                    local animator = enemyHumanoid:FindFirstChildOfClass("Animator")
                    if animator then
                        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                            -- Scan for attack, slash, swing, or weapon-active keyframes
                            local animName = string.lower(track.Animation.Name or "")
                            if string.find(animName, "slash") or string.find(animName, "swing") or string.find(animName, "attack") or string.find(animName, "stab") then
                                triggerParry()
                                break
                            end
                        end
                    end
                end
            end
        end
    end
end)

--------------------------------------------------------------------------------
-- AIMLOCK / SILENT TRACKER
--------------------------------------------------------------------------------
local function getClosestEnemy()
    local target = nil
    local maxDist = math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChildOfClass("Humanoid") then
            if p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
                local dist = (playerHumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
                if dist < maxDist then
                    target = p.Character.HumanoidRootPart
                    maxDist = dist
                end
            end
        end
    end
    return target
end

RunService.RenderStepped:Connect(function()
    if Features.Aimlock then
        local enemy = getClosestEnemy()
        if enemy then
            local cam = workspace.CurrentCamera
            cam.CFrame = CFrame.new(cam.CFrame.Position, enemy.Position)
        end
    end
end)

