task.spawn(function()
    while task.wait(0.2) do
        if Features.GodMode and playerCharacter then
            local hum = playerCharacter:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 and hum.Health < hum.MaxHealth then
                -- Request basic healing/state packet triggers directly
                local healRemote = playerCharacter:FindFirstChild("Heal") or playerCharacter:FindFirstChild("Regen")
                if healRemote and healRemote:IsA("RemoteEvent") then
                    healRemote:FireServer()
                end
                hum.Health = hum.MaxHealth
            end
        end
    end
end)

