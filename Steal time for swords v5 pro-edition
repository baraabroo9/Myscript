local function CreateDynamicReachEsp(targetPlayer)
    if targetPlayer == player then return end
    local RingEsp = Instance.new("CylinderHandleAdornment")
    RingEsp.Name = "BaraaFloorAura"
    RingEsp.Color3 = Color3.fromRGB(140, 60, 255)
    RingEsp.AlwaysOnTop = false 
    RingEsp.Transparency = 0.75
    RingEsp.Height = 0.1
    RingEsp.Parent = ScreenGui

    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not ScreenGui or not ScreenGui.Parent then
            connection:Disconnect()
            RingEsp:Destroy()
            return
        end
        if ReachSettings.EspEnabled and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") and targetPlayer.Character:FindFirstChild("Humanoid") and targetPlayer.Character.Humanoid.Health > 0 then
            RingEsp.Adornee = targetPlayer.Character.HumanoidRootPart
            RingEsp.CFrame = CFrame.new(0, -3.2, 0) * CFrame.fromAxisAngle(Vector3.new(1, 0, 0), math.rad(90))
            RingEsp.Radius = ReachSettings.CurrentReach
        else
            RingEsp.Adornee = nil
        end
    end)
end

for _, p in ipairs(Players:GetPlayers()) do CreateDynamicReachEsp(p) end
Players.PlayerAdded:Connect(function(p) CreateDynamicReachEsp(p) end)

RunService.RenderStepped:Connect(function()
    if not playerCharacter or not playerHumanoidRootPart then return end
    local myHumanoid = playerCharacter:FindFirstChildOfClass("Humanoid")
    
    if ReachSettings.HyperVelocity and myHumanoid then
        myHumanoid.WalkSpeed = 24
    elseif myHumanoid and not ReachSettings.HyperVelocity and myHumanoid.WalkSpeed == 24 then
        myHumanoid.WalkSpeed = 16
    end

    local closestPlayer = GetClosestPlayer()
    
    if closestPlayer and closestPlayer.Character and closestPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local oppRoot = closestPlayer.Character.HumanoidRootPart
        local activeTool = playerCharacter:FindFirstChildOfClass("Tool")
        
        -- Dynamic Size Reach Engine Integration
        if ReachSettings.Enabled and activeTool then
            local handle = activeTool:FindFirstChild("Handle")
            if not handle or not handle:FindFirstChild("TouchInterest") then
                for _, child in ipairs(activeTool:GetChildren()) do
                    if child:IsA("BasePart") and child:FindFirstChild("TouchInterest") then handle = child break end
                end
            end
            
            if handle then
                if lastToolTracked ~= handle then
                    originalToolSize = handle.Size
                    lastToolTracked = handle
                end
                handle.Transparency = 0
                handle.Size = Vector3.new(ReachSettings.CurrentReach, ReachSettings.CurrentReach, ReachSettings.CurrentReach)
                handle.Position = oppRoot.Position
                activeTool:Activate()
                
                ReachSettings.ComboHits = ReachSettings.ComboHits + 1
                ComboLabel.Text = "COMBO REGISTER HITS: " .. ReachSettings.ComboHits
                SpawnHitEffect(oppRoot.Position)
            end
        end
        
        -- Active Tracked Kill Aura Execution Loop
        if ReachSettings.KillAura and activeTool and (playerHumanoidRootPart.Position - oppRoot.Position).Magnitude <= ReachSettings.CurrentReach then
            activeTool:Activate()
            ReachSettings.ComboHits = ReachSettings.ComboHits + 1
            ComboLabel.Text = "COMBO REGISTER HITS: " .. ReachSettings.ComboHits
            SpawnHitEffect(oppRoot.Position)
        end
    end

    -- Background Core Vortex Loop
    if ReachSettings.VortexPull then
        for _, opp in ipairs(Players:GetPlayers()) do
            if opp ~= player and opp.Character and opp.Character:FindFirstChild("HumanoidRootPart") and opp.Character:FindFirstChild("Humanoid") then
                if opp.Character.Humanoid.Health > 0 then
                    local dist = (playerHumanoidRootPart.Position - opp.Character.HumanoidRootPart.Position).Magnitude
                    if dist <= (ReachSettings.CurrentReach + 6) and dist > 4 then
                        opp.Character.HumanoidRootPart.CFrame = playerHumanoidRootPart.CFrame * CFrame.new(0, 0, -3)
                    end
                end
            end
        end
    end
end)
