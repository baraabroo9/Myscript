local isVisualizingHit = false
local function FlashHitUI()
    BaraaHubSettings.SessionHits = BaraaHubSettings.SessionHits + 1
    SessionLabel.Text = "COMBO HITS: " .. BaraaHubSettings.SessionHits
    
    if isVisualizingHit then return end
    isVisualizingHit = true
    
    HitIndicator.TextTransparency = 0
    HitIndicator.BackgroundTransparency = 0
    indicatorStroke.Transparency = 0
    
    task.delay(0.12, function()
        local info = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        TweenService:Create(HitIndicator, info, {TextTransparency = 1, BackgroundTransparency = 1}):Play()
        TweenService:Create(indicatorStroke, info, {Transparency = 1}):Play()
        task.wait(0.2)
        isVisualizingHit = false
    end)
end

