local function CreateButton(text, order, callback)
    local btn = Instance.new("TextButton")
    btn.BackgroundColor3 = Color3.fromRGB(26, 22, 32)
    btn.Text = text .. ": OFF"
    btn.TextColor3 = Color3.fromRGB(220, 90, 90)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 11
    btn.LayoutOrder = order
    btn.Parent = ScrollFrame
    
    local cr = Instance.new("UICorner") cr.CornerRadius = UDim.new(0, 6) cr.Parent = btn
    
    local enabled = false
    btn.MouseButton1Click:Connect(function()
        enabled = not enabled
        if enabled then
            btn.Text = text .. ": ON"
            btn.TextColor3 = Color3.fromRGB(90, 240, 90)
            btn.BackgroundColor3 = Color3.fromRGB(32, 55, 42)
        else
            btn.Text = text .. ": OFF"
            btn.TextColor3 = Color3.fromRGB(220, 90, 90)
            btn.BackgroundColor3 = Color3.fromRGB(26, 22, 32)
        end
        callback(enabled)
    end)
    return btn
end

