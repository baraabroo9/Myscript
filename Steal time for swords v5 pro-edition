local function CreateDynamicReachEsp(targetPlayer)
    if targetPlayer == player then return end

    local RingEsp = Instance.new("CylinderHandleAdornment")
    RingEsp.Name = "BaraaReach_FloorAura"
    RingEsp.Color3 = Color3.fromRGB(150, 65, 255)
    RingEsp.AlwaysOnTop = false 
    RingEsp.ZIndex = 4
    RingEsp.Transparency = 0.8
    RingEsp.Height = 0.12
    RingEsp.Parent = ScreenGui

    RunService.RenderStepped:Connect(function()
        if BaraaHubSettings.EspEnabled and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") and targetPlayer.Character:FindFirstChild("Humanoid") and targetPlayer.Character.Humanoid.Health > 0 then
            local oppRoot = targetPlayer.Character.HumanoidRootPart
            RingEsp.Adornee = oppRoot
            RingEsp.CFrame = CFrame.new(0, -3.2, 0) * CFrame.fromAxisAngle(Vector3.new(1, 0, 0), math.rad(90))
            RingEsp.Radius = BaraaHubSettings.CurrentReach
        else
            RingEsp.Adornee = nil
        end
    end)
end

for _, p in ipairs(Players:GetPlayers()) do CreateDynamicReachEsp(p) end
Players.PlayerAdded:Connect(CreateDynamicReachEsp)

