local ActiveWorldDrawings = {}

local function CreateWorldESP(Instance, DisplayName, ThemeColor)
    if ActiveWorldDrawings[Instance] then return end
    
    local ESP = {
        Text = Drawing.new("Text"),
        Tracer = Drawing.new("Line")
    }
    ActiveWorldDrawings[Instance] = ESP
    
    ESP.Text.Size = 12
    ESP.Text.Center = true
    ESP.Text.Outline = true
    ESP.Text.Color = ThemeColor
    ESP.Text.Visible = false
    
    ESP.Tracer.Thickness = 1
    ESP.Tracer.Color = ThemeColor
    ESP.Tracer.Visible = false
    
    local Connection
    Connection = RunService.RenderStepped:Connect(function()
        if not Instance or not Instance.Parent or not States.WorldESP then
            ESP.Text.Visible = false
            ESP.Tracer.Visible = false
            if not Instance.Parent then
                ESP.Text:Destroy()
                ESP.Tracer:Destroy()
                ActiveWorldDrawings[Instance] = nil
                Connection:Disconnect()
            end
            return
        end
        
        local Part = Instance:IsA("BasePart") and Instance or Instance:FindFirstChildOfClass("BasePart") or Instance.PrimaryPart
        if Part then
            local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Part.Position)
            if OnScreen then
                local Distance = math.floor((RootPart.Position - Part.Position).Magnitude)
                ESP.Text.Position = Vector2.new(ScreenPos.X, ScreenPos.Y)
                ESP.Text.Text = string.format("[%s (%dM)]", DisplayName, Distance)
                ESP.Text.Visible = true
                
                if States.ObjectTracers then
                    ESP.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    ESP.Tracer.To = Vector2.new(ScreenPos.X, ScreenPos.Y)
                    ESP.Tracer.Visible = true
                else
                    ESP.Tracer.Visible = false
                end
            else
                ESP.Text.Visible = false
                ESP.Tracer.Visible = false
            end
        else
            ESP.Text.Visible = false
            ESP.Tracer.Visible = false
        end
    end)
end

