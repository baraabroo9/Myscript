local function GetClosestPlayerToMouse()
    local Target = nil
    local Dist = math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local Hum = p.Character:FindFirstChildOfClass("Humanoid")
            if Hum and Hum.Health > 0 then
                local ScreenPos, OnScreen = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
                if OnScreen then
                    local MouseDist = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(ScreenPos.X, ScreenPos.Y)).Magnitude
                    if MouseDist < Dist then
                        Target = p.Character.HumanoidRootPart
                        Dist = MouseDist
                    end
                end
            end
        end
    end
    return Target
end

-- Primary Run Update Threads
RunService.Heartbeat:Connect(function()
    if not Character or not RootPart then return end
    
    local Humanoid = Character:FindFirstChildOfClass("Humanoid")
    if not Humanoid then return end
    
    -- Speed Adjustment (Under anti-cheat bypass)
    if States.SpeedHack then
        Humanoid.WalkSpeed = States.SpeedValue
    end
    
    -- Precise NoClip
    if States.Noclip then
        for _, obj in ipairs(Character:GetDescendants()) do
            if obj:IsA("BasePart") and obj.CanCollide then
                obj.CanCollide = false
            end
        end
    end
    
    -- Infinite Stamina Allocation
    if States.InfiniteStamina then
        LocalPlayer:SetAttribute("Stamina", 100)
        LocalPlayer:SetAttribute("SprintStamina", 100)
        local InternalStam = Character:FindFirstChild("Stamina") or LocalPlayer:FindFirstChild("Stamina")
        if InternalStam and InternalStam:IsA("ValueBase") then
            InternalStam.Value = 100
        end
    end
    
    -- Fast Objective Interaction
    if States.InstantInteract then
        for _, prompt in ipairs(workspace:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") then
                prompt.HoldDuration = 0
            end
        end
    end
    
    -- Frame-One Parry Matrix
    if States.AutoParry then
        for _, enemy in ipairs(Players:GetPlayers()) do
            if enemy ~= LocalPlayer and enemy.Character and enemy.Character:FindFirstChild("HumanoidRootPart") then
                local EnemyRoot = enemy.Character.HumanoidRootPart
                local Distance = (RootPart.Position - EnemyRoot.Position).Magnitude
                
                if Distance < 13 then
                    local EnemyHum = enemy.Character:FindFirstChildOfClass("Humanoid")
                    local Animator = EnemyHum and EnemyHum:FindFirstChildOfClass("Animator")
                    if Animator then
                        for _, track in ipairs(Animator:GetPlayingAnimationTracks()) do
                            local AnimName = string.lower(track.Animation.Name or "")
                            if string.find(AnimName, "slash") or string.find(AnimName, "swing") or string.find(AnimName, "attack") then
                                local Tool = Character:FindFirstChildOfClass("Tool")
                                if Tool then
                                    Tool:Activate()
                                    local BlockRemote = Tool:FindFirstChild("Block") or Tool:FindFirstChild("Parry") or Tool:FindFirstChild("Remote")
                                    if BlockRemote and BlockRemote:IsA("RemoteEvent") then
                                        BlockRemote:FireServer(true)
                                    end
                                end
                                break
                            end
                        end
                    end
                end
            end
        end
    end
end)

-- Render updates (Aimlock & Environmental Filters)
RunService.RenderStepped:Connect(function()
    if States.Aimlock then
        local LockTarget = GetClosestPlayerToMouse()
        if LockTarget then
            local CurrentLook = Camera.CFrame
            local TargetLook = CFrame.new(Camera.CFrame.Position, LockTarget.Position)
            Camera.CFrame = CurrentLook:Lerp(TargetLook, States.AimlockSmoothness)
        end
    end
    
    if States.NoFog then
        Lighting.FogStart = 9e9
        Lighting.FogEnd = 9e9
    end
    if States.Fullbright then
        Lighting.Brightness = 2.5
        Lighting.Ambient = Color3.fromRGB(255, 255, 255)
    end
end)

