end

local function AddToggle(text, configKey)
    local btn = Instance.new("TextButton")
    btn.BackgroundColor3 = Color3.fromRGB(16, 13, 22)
    btn.Text = "  " .. text
    btn.TextColor3 = Color3.fromRGB(150, 145, 160)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 10
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Parent = PageList
    
    local cr = Instance.new("UICorner") cr.CornerRadius = UDim.new(0, 5) cr.Parent = btn
    local stroke = Instance.new("UIStroke") stroke.Thickness = 1 stroke.Color = Color3.fromRGB(30, 26, 38) stroke.Parent = btn
    
    local indicator = Instance.new("Frame")
    indicator.Size = UDim2.new(0, 12, 0, 12)
    indicator.Position = UDim2.new(1, -22, 0.5, -6)
    indicator.BackgroundColor3 = States[configKey] and Color3.fromRGB(138, 43, 226) or Color3.fromRGB(30, 26, 38)
    indicator.Parent = btn
    local ticr = Instance.new("UICorner") ticr.CornerRadius = UDim.new(1, 0) ticr.Parent = indicator

    btn.MouseButton1Click:Connect(function()
        States[configKey] = not States[configKey]
        indicator.BackgroundColor3 = States[configKey] and Color3.fromRGB(138, 43, 226) or Color3.fromRGB(30, 26, 38)
    end)
end

