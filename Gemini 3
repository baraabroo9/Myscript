-- Auto Parry Trigger
local function executeParry()
    local tool = playerCharacter:FindFirstChildOfClass("Tool")
    if tool then
        tool:Activate()
        -- Directly query network triggers to execute dagger blocking state instantly
        local blockRemote = tool:FindFirstChild("Block") or tool:FindFirstChild("Parry") or tool:FindFirstChild("Remote")
        if blockRemote and blockRemote:IsA("RemoteEvent") then
            blockRemote:FireServer(true)
        end
    end
end

-- Aimlock Target Acquisition
local function getClosestPlayer()
    local target = nil
    local maxDist = math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChildOfClass("Humanoid") then
            if p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
                local dist = (playerHumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
                if dist < maxDist then
                    target = p.Character.HumanoidRootPart
                    maxDist = dist
                end
            end
        end
    end
    return target
end

-- Core Step Integration
RunService.Heartbeat:Connect(function()
    if not playerCharacter or not playerHumanoidRootPart then return end
    
    -- Auto Parry Detection Matrix
    if Features.AutoParry then
        for _, enemy in ipairs(Players:GetPlayers()) do
            if enemy ~= player and enemy.Character and enemy.Character:FindFirstChild("HumanoidRootPart") then
                local enemyRoot = enemy.Character.HumanoidRootPart
                local distance = (playerHumanoidRootPart.Position - enemyRoot.Position).Magnitude
                
                if distance < 12 then
                    local enemyHum = enemy.Character:FindFirstChildOfClass("Humanoid")
                    local animator = enemyHum and enemyHum:FindFirstChildOfClass("Animator")
                    if animator then
                        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                            local animName = string.lower(track.Animation.Name or "")
                            if string.find(animName, "slash") or string.find(animName, "swing") or string.find(animName, "attack") then
                                executeParry()
                                break
                            end
                        end
                    end
                end
            end
        end
    end

    -- Infinite Stamina & Speed Run-checks
    if Features.InfiniteStamina then
        local myHum = playerCharacter:FindFirstChildOfClass("Humanoid")
        if myHum then
            -- Reset classic stamina variables located in either local scripts or player attributes
            player:SetAttribute("Stamina", 100)
            player:SetAttribute("SprintStamina", 100)
            local stamObj = playerCharacter:FindFirstChild("Stamina") or player:FindFirstChild("Stamina")
            if stamObj and stamObj:IsA("ValueBase") then
                stamObj.Value = 100
            end
        end
    end

    -- Instant Interaction Bypass (Speeds up repair/unlock hold triggers)
    if Features.InstantInteraction then
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                desc.HoldDuration = 0
            end
        end
    end

    -- Kill Aura Failsafe Loop
    if Features.KillAura then
        local activeTool = playerCharacter:FindFirstChildOfClass("Tool")
        if activeTool then
            local enemyTarget = getClosestPlayer()
            if enemyTarget then
                local distance = (playerHumanoidRootPart.Position - enemyTarget.Position).Magnitude
                if distance <= Features.KillAuraRange then
                    activeTool:Activate()
                    local touchInterest = activeTool:FindFirstChildWhichIsA("TouchTransmitter", true)
                    if touchInterest and firetouchinterest then
                        firetouchinterest(touchInterest.Parent, enemyTarget, 0)
                        firetouchinterest(touchInterest.Parent, enemyTarget, 1)
                    end
                end
            end
        end
    end
end)

