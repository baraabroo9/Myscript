local function createESP(part)
    local box = Instance.new("BoxHandleAdornment")
    box.Size = part.Size + Vector3.new(0.1,0.1,0.1)
    box.AlwaysOnTop = true
    box.ZIndex = 0
    box.Adornee = part
    box.Color3 = Color3.fromRGB(255,255,0)
    box.Transparency = 0.5
    box.Parent = part
end
local function highlightTPS()
    local TPSSystem = workspace:FindFirstChild("TPSSystem")
    if TPSSystem then
        local TPSPart = TPSSystem:FindFirstChild("TPS")
        if TPSPart and TPSPart:IsA("BasePart") then createESP(TPSPart) end
    end
end
local function unhighlightTPS()
    local TPSSystem = workspace:FindFirstChild("TPSSystem")
    if TPSSystem then
        local TPSPart = TPSSystem:FindFirstChild("TPS")
        if TPSPart and TPSPart:IsA("BasePart") then
            for _, adornment in ipairs(TPSPart:GetChildren()) do
                if adornment:IsA("BoxHandleAdornment") then adornment:Destroy() end
            end
        end
    end
end
ballTab:Button({ Title = "Ball ESP", Desc = "Highlight TPS Ball", Callback = function() highlightTPS() end })
