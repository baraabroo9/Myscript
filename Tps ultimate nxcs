        if root then  
            for _, ball in ipairs(BallTable) do  
                if ball and ball.Parent then  
                    local dist = (root.Position - ball.Position).Magnitude  
                    local function MultiTouch(part, b)  
                        firetouchinterest(part, b, 0)  
