-- VISUAL REACH DYNAMIC ESP ENGINE
--------------------------------------------------------------------------------
local function CreateDynamicReachEsp(targetPlayer)
    if targetPlayer == player then return end

    local VisualBox = Instance.new("BoxHandleAdornment")
    VisualBox.Name = "DynamicReach_Hitbox"
    VisualBox.Color3 = Color3.fromRGB(255, 50, 50)
    VisualBox.AlwaysOnTop = true
    VisualBox.ZIndex = 4
    VisualBox.Transparency = 0.85
    VisualBox.Parent = ScreenGui

    RunService.RenderStepped:Connect(function()
        if BaraaHubSettings.EspEnabled and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") and targetPlayer.Character:FindFirstChild("Humanoid") and targetPlayer.Character.Humanoid.Health > 0 then
            VisualBox.Adornee = targetPlayer.Character.HumanoidRootPart
            local dynamicSize = BaraaHubSettings.CurrentReach
            VisualBox.Size = Vector3.new(dynamicSize, dynamicSize + 3, dynamicSize)
        else
            VisualBox.Adornee = nil
        end
    end)
end

for _, p in ipairs(Players:GetPlayers()) do CreateDynamicReachEsp(p) end
Players.PlayerAdded:Connect(CreateDynamicReachEsp)


--------------------------------------------------------------------------------
-- HIGH-VELOCITY RUNTIME (FLING, NO-COLLISION, & AUTO-KILL)
--------------------------------------------------------------------------------
RunService.RenderStepped:Connect(function()
    if not playerCharacter or not playerCharacter:FindFirstChild("HumanoidRootPart") then return end
    
    local myRoot = playerCharacter.HumanoidRootPart
    local activeTool = playerCharacter:FindFirstChildOfClass("Tool")
    local handle = activeTool and (activeTool:FindFirstChild("Handle") or activeTool:FindFirstChildOfClass("BasePart"))

    -- Disable local player collisions so you can pass seamlessly right through them
    for _, part in ipairs(playerCharacter:GetChildren()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end

    for _, opp in ipairs(Players:GetPlayers()) do
        if opp ~= player and opp.Character and opp.Character:FindFirstChild("HumanoidRootPart") and opp.Character:FindFirstChild("Humanoid") then
            local oppRoot = opp.Character.HumanoidRootPart
            local oppHumanoid = opp.Character.Humanoid

            if oppHumanoid.Health > 0 then
                -- Disable target collisions dynamically while managing them
                for _, part in ipairs(opp.Character:GetChildren()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end

                local distanceToMe = (myRoot.Position - oppRoot.Position).Magnitude
                local distanceToSafeZone = (oppRoot.Position - BaraaHubSettings.SafeZoneCenter).Magnitude
                local isInsideSafeZone = distanceToSafeZone <= BaraaHubSettings.SafeZoneRadius

                -- 1. INSTANT PROXIMITY FLING ENGINE
                if BaraaHubSettings.SafeZonePusher and isInsideSafeZone and distanceToMe <= BaraaHubSettings.FlingDistance then
                    -- Calculate escape push vector directed away from map core
                    local pushDirection = (oppRoot.Position - BaraaHubSettings.SafeZoneCenter).Unit
                    if pushDirection.Magnitude == 0 or pushDirection ~= pushDirection then 
                        pushDirection = Vector3.new(1, 0, 1).Unit 
                    end
                    
                    -- Inject aggressive physical forces to spin and eject the player model cleanly
                    oppRoot.AssemblyLinearVelocity = (pushDirection * 250) + Vector3.new(0, 120, 0)
                    oppRoot.AssemblyAngularVelocity = Vector3.new(0, 5000, 0)
                end

                -- 2. ARENA AUTO-KILL ALL
                if BaraaHubSettings.AutoKillArena and not isInsideSafeZone and handle then
                    local touchInterest = handle:FindFirstChildOfClass("TouchTransmitter") or handle:FindFirstChild("TouchInterest")
                    if touchInterest then
                        firetouchinterest(handle, oppRoot, 0)
                        task.wait()
                        firetouchinterest(handle, oppRoot, 1)
                    end
                end

                -- 3. STANDARD SLIDER REACH
                if BaraaHubSettings.ReachEnabled and not BaraaHubSettings.AutoKillArena and handle then
                    if distanceToMe <= BaraaHubSettings.CurrentReach then
                        local touchInterest = handle:FindFirstChildOfClass("TouchTransmitter") or handle:FindFirstChild("TouchInterest")
                        if touchInterest then
                            firetouchinterest(handle, oppRoot, 0)
                            task.wait()
                            firetouchinterest(handle, oppRoot, 1)
                        end
                    end
                end

            end
        end
    end
end)
