local function StyleButton(button, state, defaultText, activeText)
    if state then
        button.Text = activeText
        button.TextColor3 = Color3.fromRGB(70, 255, 70)
        button.BackgroundColor3 = Color3.fromRGB(30, 45, 35)
    else
        button.Text = defaultText
        button.TextColor3 = Color3.fromRGB(255, 70, 70)
        button.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    end
end

