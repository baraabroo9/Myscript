local function createWorldESP(instance, labelText, color)
    local text = Drawing.new("Text")
    text.Size = 13
    text.Center = true
    text.Outline = true
    text.Color = color
    text.Visible = false
    
    local renderConnection
    renderConnection = RunService.RenderStepped:Connect(function()
        if not instance or not instance.Parent or not Features.WorldESP then
            text.Visible = false
            if not instance.Parent then
                text:Destroy()
                renderConnection:Disconnect()
            end
            return
        end
        
        local targetPosition
        if instance:IsA("Model") then
            local primary = instance.PrimaryPart or instance:FindFirstChildOfClass("BasePart")
            targetPosition = primary and primary.Position
        elseif instance:IsA("BasePart") then
            targetPosition = instance.Position
        end
        
        if targetPosition then
            local vector, onScreen = camera:WorldToViewportPoint(targetPosition)
            if onScreen then
                local dist = math.floor((playerHumanoidRootPart.Position - targetPosition).Magnitude)
                text.Position = Vector2.new(vector.X, vector.Y)
                text.Text = "[" .. labelText .. " (" .. tostring(dist) .. "m)]"
                text.Visible = true
            else
                text.Visible = false
            end
        else
            text.Visible = false
        end
    end)
end

-- Scans the Workspace and registers functional game assets based on structural names/tags
local function scanWorldProps()
    for _, obj in ipairs(workspace:GetDescendants()) do
        -- 1. Generators
        if string.find(string.lower(obj.Name), "generator") and (obj:IsA("Model") or obj:IsA("BasePart")) then
            createWorldESP(obj, "Generator", Color3.fromRGB(0, 191, 255))
        -- 2. Hooks / Spikes / Sacrifice Points
        elseif (string.find(string.lower(obj.Name), "hook") or string.find(string.lower(obj.Name), "spike")) and (obj:IsA("Model") or obj:IsA("BasePart")) then
            createWorldESP(obj, "Sacrifice Hook", Color3.fromRGB(220, 20, 60))
        -- 3. Loop Structures / Pallets
        elseif string.find(string.lower(obj.Name), "pallet") and (obj:IsA("Model") or obj:IsA("BasePart")) then
            createWorldESP(obj, "Pallet Obstacle", Color3.fromRGB(244, 164, 96))
        -- 4. Escape / Gates / Exit Panels
        elseif (string.find(string.lower(obj.Name), "gate") or string.find(string.lower(obj.Name), "exit")) and (obj:IsA("Model") or obj:IsA("BasePart")) then
            createWorldESP(obj, "Escape Gate", Color3.fromRGB(50, 205, 50))
        -- 5. Windows / Vaults
        elseif string.find(string.lower(obj.Name), "window") and (obj:IsA("Model") or obj:IsA("BasePart")) then
            createWorldESP(obj, "Vault Window", Color3.fromRGB(230, 230, 250))
        end
    end
end

