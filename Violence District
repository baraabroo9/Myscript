local tabs = {}
local function CreatePageButton(name, order)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 0, 32)
    button.BackgroundColor3 = Color3.fromRGB(15, 12, 20)
    button.BackgroundTransparency = 1
    button.Text = "   " .. name
    button.TextColor3 = Color3.fromRGB(150, 145, 160)
    button.Font = Enum.Font.GothamSemibold
    button.TextSize = 11
    button.TextXAlignment = Enum.TextXAlignment.Left
    button.LayoutOrder = order
    button.Parent = TabContainer
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 5)
    corner.Parent = button
    
    button.MouseButton1Click:Connect(function()
        for _, otherBtn in ipairs(TabContainer:GetChildren()) do
            if otherBtn:IsA("TextButton") then
                otherBtn.BackgroundTransparency = 1
                otherBtn.TextColor3 = Color3.fromRGB(150, 145, 160)
            end
        end
        button.BackgroundTransparency = 0
        button.BackgroundColor3 = Color3.fromRGB(18, 15, 24)
        button.TextColor3 = Color3.fromRGB(255, 255, 255)
        Features.ActiveTab = name
        
        -- Clean current UI grid contents
        for _, item in ipairs(PageList:GetChildren()) do
            if not item:IsA("UIGridLayout") then item:Destroy() end
        end
        tabs[name]()
    end)
end

local function AddToggle(text, configKey, callback)
    local btn = Instance.new("TextButton")
    btn.BackgroundColor3 = Color3.fromRGB(16, 13, 22)
    btn.Text = "  " .. text
    btn.TextColor3 = Color3.fromRGB(150, 145, 160)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 10
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Parent = PageList
    
    local cr = Instance.new("UICorner") cr.CornerRadius = UDim.new(0, 5) cr.Parent = btn
    local stroke = Instance.new("UIStroke") stroke.Thickness = 1 stroke.Color = Color3.fromRGB(30, 26, 38) stroke.Parent = btn
    
    local toggleIndicator = Instance.new("Frame")
    toggleIndicator.Size = UDim2.new(0, 12, 0, 12)
    toggleIndicator.Position = UDim2.new(1, -22, 0.5, -6)
    toggleIndicator.BackgroundColor3 = Features[configKey] and Color3.fromRGB(138, 43, 226) or Color3.fromRGB(30, 26, 38)
    toggleIndicator.Parent = btn
    local ticr = Instance.new("UICorner") ticr.CornerRadius = UDim.new(1, 0) ticr.Parent = toggleIndicator

    btn.MouseButton1Click:Connect(function()
        Features[configKey] = not Features[configKey]
        toggleIndicator.BackgroundColor3 = Features[configKey] and Color3.fromRGB(138, 43, 226) or Color3.fromRGB(30, 26, 38)
        if callback then callback(Features[configKey]) end
    end)
end

