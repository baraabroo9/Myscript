local function createPlayerESP(p)
    if p == player then return end
    
    local esp = {
        Box = Drawing.new("Square"),
        Tracer = Drawing.new("Line"),
        HealthBarOutline = Drawing.new("Line"),
        HealthBar = Drawing.new("Line"),
        Text = Drawing.new("Text")
    }
    
    -- Setup visual styling
    esp.Box.Thickness = 1.5
    esp.Box.Color = Color3.fromRGB(138, 43, 226)
    esp.Box.Filled = false
    
    esp.Tracer.Thickness = 1
    esp.Tracer.Color = Color3.fromRGB(255, 255, 255)
    
    esp.HealthBarOutline.Thickness = 3
    esp.HealthBarOutline.Color = Color3.fromRGB(0, 0, 0)
    
    esp.HealthBar.Thickness = 1.5
    esp.HealthBar.Color = Color3.fromRGB(0, 255, 0)
    
    esp.Text.Size = 13
    esp.Text.Center = true
    esp.Text.Outline = true
    esp.Text.Color = Color3.fromRGB(255, 255, 255)
    
    local renderConnection
    renderConnection = RunService.RenderStepped:Connect(function()
        if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") or not Features.PlayerESP then
            esp.Box.Visible = false
            esp.Tracer.Visible = false
            esp.HealthBarOutline.Visible = false
            esp.HealthBar.Visible = false
            esp.Text.Visible = false
            if not p.Parent then
                for _, obj in pairs(esp) do obj:Destroy() end
                renderConnection:Disconnect()
            end
            return
        end
        
        local root = p.Character.HumanoidRootPart
        local hum = p.Character:FindFirstChildOfClass("Humanoid")
        local rootPos, onScreen = camera:WorldToViewportPoint(root.Position)
        
        if onScreen and hum and hum.Health > 0 then
            local top, _ = camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0))
            local bottom, _ = camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3.5, 0))
            local height = math.abs(top.Y - bottom.Y)
            local width = height / 1.5
            
            -- Draw Box ESP
            if Features.BoxESP then
                esp.Box.Size = Vector2.new(width, height)
                esp.Box.Position = Vector2.new(rootPos.X - width / 2, rootPos.Y - height / 2)
                esp.Box.Visible = true
            else
                esp.Box.Visible = false
            end
            
            -- Draw Tracers (Snap to Bottom-Center)
            if Features.TracerESP then
                esp.Tracer.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                esp.Tracer.To = Vector2.new(rootPos.X, rootPos.Y + (height / 2))
                esp.Tracer.Visible = true
            else
                esp.Tracer.Visible = false
            end
            
            -- Draw Dynamic Health Bar
            if Features.HealthBarESP then
                local barYOffset = (height * (hum.Health / hum.MaxHealth))
                esp.HealthBarOutline.From = Vector2.new(rootPos.X - (width / 2) - 6, rootPos.Y + (height / 2))
                esp.HealthBarOutline.To = Vector2.new(rootPos.X - (width / 2) - 6, rootPos.Y - (height / 2))
                esp.HealthBarOutline.Visible = true
                
                esp.HealthBar.From = Vector2.new(rootPos.X - (width / 2) - 6, rootPos.Y + (height / 2))
                esp.HealthBar.To = Vector2.new(rootPos.X - (width / 2) - 6, (rootPos.Y + (height / 2)) - barYOffset)
                esp.HealthBar.Color = Color3.fromHSV((hum.Health/hum.MaxHealth) * 0.3, 1, 1) -- Smooth transition from red to green
                esp.HealthBar.Visible = true
            else
                esp.HealthBarOutline.Visible = false
                esp.HealthBar.Visible = false
            end
            
            -- Name & Distance Display
            local dist = math.floor((playerHumanoidRootPart.Position - root.Position).Magnitude)
            esp.Text.Position = Vector2.new(rootPos.X, (rootPos.Y - height / 2) - 15)
            esp.Text.Text = string.upper(p.Name) .. " [" .. tostring(dist) .. "m]"
            esp.Text.Visible = true
        else
            esp.Box.Visible = false
            esp.Tracer.Visible = false
            esp.HealthBarOutline.Visible = false
            esp.HealthBar.Visible = false
            esp.Text.Visible = false
        end
    end)
end

