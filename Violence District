-- Custom metatable bypass hook for dynamic movement / knockbacks
local mt = getrawmetatable(game)
if mt and setreadonly then
    setreadonly(mt, false)
    local oldNewIndex = mt.__newindex
    
    mt.__newindex = newcclosure(function(self, key, value)
        if not checkcaller() and Features.AntiKnock then
            if self:IsA("BodyVelocity") or self:IsA("LinearVelocity") or self:IsA("VectorForce") then
                return
            end
            if self.Name == "HumanoidRootPart" and (key == "Velocity" or key == "AssemblyLinearVelocity") then
                return
            end
        end
        return oldNewIndex(self, key, value)
    end)
    setreadonly(mt, true)
end

